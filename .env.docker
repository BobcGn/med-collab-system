# ============================================
# Med Collab System - Docker Environment Config
# ============================================

# JWT Secret (shared across all services, must be >= 256 bits)
JWT_SECRET=med-collab-jwt-secret-change-in-production-min-256-bits!!

# Database (TiDB - MySQL compatible, port 4000)
MYSQL_PORT=4000
DB_USER=Hyy
DB_PASSWORD=hyy20060420

# Nginx
NGINX_PORT=80

# Metric Service - Segmentation
METRIC_SEGMENTATION_ENABLED=true
SEGMENTATION_BACKEND=mock

# DeepSeek AI (optional, leave empty if not using)
DEEPSEEK_API_KEY=
