SEGMENTATION_SERVICE_ENVIRONMENT=local
SEGMENTATION_SERVICE_CONFIG_FILE=
SEGMENTATION_SERVICE_APP_NAME=segmentation-service
SEGMENTATION_SERVICE_APP_VERSION=0.1.0
SEGMENTATION_SERVICE_API_PREFIX=/api/v1
SEGMENTATION_SERVICE_HOST=0.0.0.0
SEGMENTATION_SERVICE_PORT=8091
SEGMENTATION_SERVICE_LOG_LEVEL=INFO
SEGMENTATION_SERVICE_INFERENCE_BACKEND=mock
SEGMENTATION_SERVICE_MODEL_NAME=unet-bootstrap
SEGMENTATION_SERVICE_MODEL_VERSION=0.1.0
SEGMENTATION_SERVICE_MODEL_WEIGHTS_PATH=
SEGMENTATION_SERVICE_DEVICE=cpu
SEGMENTATION_SERVICE_ALLOW_RANDOM_WEIGHTS=true
SEGMENTATION_SERVICE_INPUT_HEIGHT=256
SEGMENTATION_SERVICE_INPUT_WIDTH=256
SEGMENTATION_SERVICE_IN_CHANNELS=1
SEGMENTATION_SERVICE_OUTPUT_CLASSES=1
SEGMENTATION_SERVICE_BASE_CHANNELS=32
SEGMENTATION_SERVICE_LESION_CLASS_INDEX=0
SEGMENTATION_SERVICE_PROBABILITY_THRESHOLD=0.5
SEGMENTATION_SERVICE_MIN_REGION_PIXELS=24
SEGMENTATION_SERVICE_MIN_CONFIDENCE=0.55
SEGMENTATION_SERVICE_PIXEL_SPACING_MM=0.7
SEGMENTATION_SERVICE_MAX_CONTOUR_POINTS=48
SEGMENTATION_SERVICE_REQUEST_TIMEOUT_SECONDS=30
SEGMENTATION_SERVICE_ARTIFACTS_DIR=var/artifacts
SEGMENTATION_SERVICE_RETURN_ARTIFACTS=true
